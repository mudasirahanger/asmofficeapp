{
  "name": "desktop",
  "version": "1.1.7",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder --mac --win --linux"
  },
  "keywords": [],
  "author": "ASM Office",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.officehub.app",
    "productName": "OfficeHub",
    "directories": {
      "output": "../downloads"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "Office Hub"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "electron-serve": "^1.3.0"
  }
}
