{
  "name": "desktop",
  "version": "1.1.9",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "build": "electron-builder --mac --win --linux",
    "build:legacy": "bash build-legacy.sh"
  },
  "keywords": [],
  "author": "ASM Office",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.officehub.app",
    "productName": "OfficeHub",
    "publish": [
      {
        "provider": "github",
        "owner": "mudasirahanger",
        "repo": "asmofficeapp"
      }
    ],
    "directories": {
      "output": "../downloads"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "Office Hub"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "electron-serve": "^1.3.0",
    "electron-updater": "^6.8.9"
  }
}
